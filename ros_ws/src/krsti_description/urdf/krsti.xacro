<?xml version="1.0" ?>
<robot name="krsti" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find krsti_description)/urdf/materials.xacro" />
<xacro:include filename="$(find krsti_description)/urdf/krsti.trans" />

<!-- ─── ros2_control ──────────────────────────────────────────────────────── -->
<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>
  <joint name="Revolute 5">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="Revolute 6">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

<!-- ─── Gazebo ros2_control plugin ──────────────────────────────────────── -->
<gazebo>
  <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <parameters>$(find krsti_description)/config/ros2_control.yaml</parameters>
  </plugin>
</gazebo>

<link name="base_link">
  <inertial>
    <origin xyz="0.114155970042646 0.044227959143786 0.238475499685274" rpy="0 0 0"/>
    <mass value="1.58286526308532"/>
    <inertia ixx="0.00269139609632445" iyy="0.00157610698082541" izz="0.00174038472267906" ixy="2.72366021894285e-05" iyz="-6.14136418481577e-05" ixz="0.00016429037708876"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://krsti_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://krsti_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

