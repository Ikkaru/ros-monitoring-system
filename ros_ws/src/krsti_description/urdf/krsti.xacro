<joint name="Rigid 2" type="fixed">
  <origin xyz="0.113161 0.030237 0.179968" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="pinggang_dey_1"/>
</joint>

<joint name="Revolute 5" type="continuous">
  <origin xyz="0.111644 0.098144 0.264468" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="TANGAN_KIRI_v1_1"/>
  <axis xyz="-0.0 1.0 -0.0"/>
</joint>

<joint name="Revolute 6" type="continuous">
  <origin xyz="0.111644 -0.007856 0.264468" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="TANGAN_KANAN_v1_1"/>
  <axis xyz="-0.0 -1.0 0.0"/>
</joint>

<joint name="Rigid 10" type="fixed">
  <origin xyz="0.038359 0.059494 -0.051" rpy="0 0 0"/>
  <parent link="pinggang_dey_1"/>
  <child link="KAKI_KIRI_v1_1"/>
</joint>

<joint name="Rigid 11" type="fixed">
  <origin xyz="0.000576 -0.044878 -0.051" rpy="0 0 0"/>
  <parent link="pinggang_dey_1"/>
  <child link="KAKI_KANAN_v1_1"/>
</joint>

</robot>
