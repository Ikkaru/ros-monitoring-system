{
  "name": "ROS Monitoring System",
  "dockerComposeFile": "../docker/docker-compose.yml",
  "service": "ros-core",
  "workspaceFolder": "/root/ros_ws",

  "features": {},

  "forwardPorts": [8765, 5000],
  "portsAttributes": {
    "8765": { "label": "Foxglove Bridge" },
    "5000": { "label": "File Manager" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "smilerobotics.urdf",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },

   "postAttachCommand": "source /opt/ros/jazzy/setup.bash && source /root/ros_ws/install/setup.bash 2>/dev/null || true",

  "remoteEnv": {
    "ROS_DISTRO": "jazzy",
    "ROS_DOMAIN_ID": "0",
    "DISPLAY": "${localEnv:DISPLAY}"
  },

  "mounts": [
    "source=${localWorkspaceFolder}/ros_ws,target=/root/ros_ws,type=bind"
  ]
}