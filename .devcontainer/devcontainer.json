{
  "name": "ROS Monitoring System",
  "dockerComposeFile": "../docker/docker-compose.yml",
  "service": "ros-core",
  "workspaceFolder": "/root/ros_ws",

  "features": {},

  "forwardPorts": [6080, 5901, 8765, 5000],
  "portsAttributes": {
    "6080": {
      "label": "Gazebo Display (noVNC)",
      "onAutoForward": "openBrowser"
    },
    "5901": {
      "label": "TurboVNC Direct",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "smilerobotics.urdf",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },

   "postAttachCommand": "source /opt/ros/humble/setup.bash && source /root/ros_ws/install/setup.bash 2>/dev/null || true",

  "remoteEnv": {
    "ROS_DISTRO": "humble",
    "ROS_DOMAIN_ID": "0",
    "DISPLAY": ":1",
    "VGL_DISPLAY": "egl",        
    "VGL_REFRESHRATE": "60",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all"
  },

  "mounts": [
    "source=${localWorkspaceFolder}/ros_ws,target=/root/ros_ws,type=bind"
  ]
}